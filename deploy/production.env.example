# Domain handled by Caddy. Use one host or comma-separated hosts, for example:
# APP_DOMAIN=example.com
# APP_DOMAIN=example.com, www.example.com
APP_DOMAIN=helpdesk.macieserafin.pl

# PostgreSQL
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=change-this-to-a-long-random-password

# Backend
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://helpdesk.macieserafin.pl
APP_SECURITY_BASIC_AUTH_ENABLED=false

# Demo seed stays enabled for presentation, but production requires custom passwords.
APP_DEMO_SEED_ENABLED=true
APP_DEMO_SEED_ACCOUNTS_ENABLED=true
APP_DEMO_SEED_CATEGORIES_ENABLED=true
APP_DEMO_SEED_TICKETS_ENABLED=true
APP_DEMO_SEED_REQUIRE_CUSTOM_PASSWORDS=true
APP_DEMO_SEED_USER_PASSWORD=change-this-user-password
APP_DEMO_SEED_AGENT_PASSWORD=change-this-agent-password
APP_DEMO_SEED_ADMIN_PASSWORD=change-this-admin-password
