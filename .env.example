# PostgreSQL
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk

# Ports exposed on the host
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Backend (optional overrides)
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://macieserafin.pl
APP_SECURITY_BASIC_AUTH_ENABLED=false
